							"var jsonData = pm.response.json();\r",
							"\r",
							"//проверка, что ключ data является массивом\r",
							"pm.test(\"Check body data is array\", function () {\r",
							" pm.expect(jsonData.data).to.be.an('array');\r",
							"});\r",
							"\r",
							"//проверка, что ключ id является строкой\r",
							"pm.test(\"Check body data is string\", function () {\r",
							" pm.expect(jsonData.data[0].id).to.be.an('string');\r",
							"});\r",
							"\r",
							"//проверка, записей на странице 20  (нумерация с 0)\r",
							"pm.test(\"Check body data[19] is string\", function () {\r",
							" pm.expect(jsonData.data[19].id).to.be.an('string');\r",
							"});\r",
